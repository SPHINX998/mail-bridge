# =========================
# mail-bridge public example
# =========================

# App
APP_HOST=127.0.0.1
APP_PORT=8787

# Gmail
GMAIL_USER_EMAIL=your-gmail@gmail.com
GMAIL_WATCH_TOPIC_NAME=projects/your-gcp-project/topics/your-gmail-topic
GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly
GMAIL_WATCH_LABEL_IDS=INBOX
GMAIL_WATCH_LABEL_FILTER_BEHAVIOR=include
GMAIL_OAUTH_CLIENT_FILE=credentials.json
GMAIL_OAUTH_TOKEN_FILE=.secrets/gmail-token.json
GMAIL_WATCH_CHECK_INTERVAL_MINUTES=1440
GMAIL_WATCH_RENEW_MARGIN_HOURS=24

# Pub/Sub
PUBSUB_MODE=streaming_pull
PUBSUB_SUBSCRIPTION_NAME=projects/your-gcp-project/subscriptions/your-gmail-subscription
PUBSUB_EXPECTED_AUDIENCE=
PUBSUB_EXPECTED_SERVICE_ACCOUNT_EMAIL=
GCP_SERVICE_ACCOUNT_FILE=.secrets/gcloud-adc.json

# Processing
STATE_DB_PATH=data/mail-bridge.db
BODY_PREVIEW_BYTES=4096
MAX_ATTACHMENT_NAMES=8
OPENCLAW_COMMAND=C:/Users/your-user/AppData/Roaming/npm/openclaw.cmd
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION_ID=mail-bridge-inbox-clean
OPENCLAW_JSON_PROVIDER=
OPENCLAW_JSON_MODEL=claude-sonnet-4-6
OPENCLAW_JSON_THINKING_LEVEL=off
OPENCLAW_TIMEOUT_SECONDS=180

# Rules
IMPORTANCE_POLICY_NOTE=Use AI to judge whether the email matters to me.
MEMENTO_RULES_FILE=D:/path/to/memento/data/mail-bridge-importance.json

# Notification
NOTIFIER_MODE=openclaw_qqbot
QQ_TARGET=qqbot:c2c:YOUR_OPENID
